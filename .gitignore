# Python caches and build output
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# Local virtual environments
.venv/
venv/
env/

# PyInstaller and release artifacts
build/
dist/
release/
*.spec

# Local runtime files
logs/
gui_settings.json
config.ini
results.xlsx
results*.xlsx
results*-*.png
*.corrupt-*.xlsx
startup_error.log

# Local/reference PDFs are not needed for source distribution
Manuals/
*.pdf

# Local VBA exports are reference material, not part of the Python/EXE release
vba/

# Locally collected third-party installers are packaged, not versioned
dependencies/*
!dependencies/README.md

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.code-workspace
